function hulk_fn_inc_0(hulk_param_x_1) ; kind=global
{
  local hulk_tmp_number_0
  local hulk_tmp_arith_1
  hulk_tmp_number_0 = const_number 1
  hulk_tmp_arith_1 = add hulk_param_x_1 hulk_tmp_number_0
  return hulk_tmp_arith_1
}

function hulk_main() ; kind=entry
{
  local hulk_tmp_call_2
